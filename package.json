{
  "name": "hono-boilerplate",
  "description": "boilerplate to run a js server using bun or node",
  "version": "1.6.3",
  "author": "Marcos <hello@marcosrjjunior.com>",
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/node.ts",
    "build": "tsc -p .",
    "start": "node ./dist/node.js",
    "test": "bun test ./src/app",
    "test:integration": "bun test --preload ./src/tests/setup.ts ./src/tests",
    "check-types": "tsc --noemit --skipLibCheck",
    "lint": "eslint ./src --max-warnings 0 && pnpm check-types",
    "lint:fix": "eslint ./src --fix",
    "prettier": "prettier --write ./src"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.60.2",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.10.6",
    "@types/shelljs": "^0.10.0",
    "@types/uuid": "^10.0.0",
    "bun": "^1.3.12",
    "hono": "^4.12.12",
    "shelljs": "^0.10.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}